# GitHub 配置
GITHUB_USERNAME=your_github_username
GITHUB_TOKEN=ghp_your_token_here

# GLM-4 API 配置
GLM_API_KEYS=key1,key2,key3
GLM_BASE_URL=https://open.bigmodel.cn/api/anthropic
GLM_MODEL=glm-4

# 同步配置
SYNC_INTERVAL_MINUTES=60

# 队列配置
MAX_RETRY_COUNT=3
TASK_CONCURRENCY=2

# 路径配置
REPO_CLONE_PATH=./data/repos
LOG_PATH=./logs
